# Dev-only Dockerfile, used by docker-compose.dev.yml (fallback dev path).
# The Railway deploy does NOT use this file: Railway builds the backend/
# folder with Railpack, no Dockerfile needed (see DEPLOY.md).

FROM python:3.12-slim

# uv: fast Python package manager (reads pyproject.toml + uv.lock)
RUN pip install --no-cache-dir uv

WORKDIR /app

# Install dependencies first (cached layer if pyproject doesn't change)
COPY backend/pyproject.toml backend/uv.lock ./
RUN uv sync --frozen --no-install-project || uv sync

# Source code is bind-mounted at runtime; this COPY is just a fallback
COPY backend/ ./

EXPOSE 8000

CMD ["uv", "run", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
